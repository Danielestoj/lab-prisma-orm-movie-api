{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "."
  },
  "include": ["src", "prisma", "prisma.config.ts"],
  "exclude": ["node_modules"]
}

